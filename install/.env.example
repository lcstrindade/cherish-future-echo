# ============================================================================
# Bivvo Docs — Exemplo de variáveis de ambiente
# Copie este arquivo para .env na raiz do projeto e preencha os valores.
# NUNCA faça commit do .env com credenciais reais.
# ============================================================================

# --- Supabase (obrigatório) ---
# URL do projeto Supabase (self-hosted ou cloud). Ex.: https://xxxx.supabase.co
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Espelhos VITE_* (expostos ao browser — apenas chaves públicas!)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Admin (login do painel /auth) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# --- Sessão (cookie assinado). Gere com: openssl rand -hex 32 ---
SESSION_SECRET=

# --- Servidor Node ---
PORT=3000
HOST=127.0.0.1
NODE_ENV=production